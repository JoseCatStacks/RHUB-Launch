                // Save back (safe)
                let all = JSON.parse(safeGetItem('rHubDynamicLaunches') || '[]');
                const idx = all.findIndex(l => l.id === launchId);
                if (idx !== -1) all[idx] = launch;
                safeSetItem('rHubDynamicLaunches', JSON.stringify(all));
                
