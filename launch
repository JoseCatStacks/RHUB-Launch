        function executeTrade() {
            const pair = document.getElementById('pair-select').value;
            const amount = parseFloat(document.getElementById('order-amount').value);
            if (!amount || amount <= 0) {
                showToast('Enter a valid amount', 'error');
                return;
            }

            const [base, quote] = pair.split('/');
            let price = 1.84;
            
            if (pair === 'ETH/USDC') price = 3120;
            else if (pair === 'SOL/USDC') price = 148;
            else if (pair === 'BTC/USDC') price = 96400;

            const receiveAmount = amount / price;

            if (currentOrderType === 0) { // BUY
                if (balances[quote] < amount) {
                    showToast(`Insufficient ${quote}`, 'error');
                    return;
                }
                balances[quote] -= amount;
                balances[base] = (balances[base] || 0) + receiveAmount;
                showToast(`Bought ${receiveAmount.toFixed(4)} ${base} for $${amount}`, 'success');
            } else { // SELL
                if ((balances[base] || 0) < receiveAmount) {
                    showToast(`Insufficient ${base}`, 'error');
                    return;
                }
                balances[base] -= receiveAmount;
                balances[quote] = (balances[quote] || 0) + amount;
                showToast(`Sold ${receiveAmount.toFixed(4)} ${base} for $${amount}`, 'success');
            }

            // Refresh UI
            updatePortfolioUI();
            updateTradePair();
            
            // Small chart bump animation effect
            if (chartInstance) {
                const newData = chartInstance.data.datasets[0].data.map(v => v * (0.995 + Math.random() * 0.01));
                chartInstance.data.datasets[0].data = newData;
                chartInstance.update();
            }
        }

